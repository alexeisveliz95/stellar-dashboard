---
import BaseLayout from "../layouts/BaseLayout.astro";
import DashboardHeader from "../components/DashboardHeader.astro";
import StatsCards from "../components/StatsCards.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import TrendingNowTable from "../components/TrendingNowTable.astro";
import QualityTable from "../components/QualityTable.astro";
import CuratedTable from "../components/CuratedTable.astro";
import TrendChart from "../components/TrendChart.astro";
import Footer from "../components/Footer.astro";
import {
  parseDashboard,
  loadAllCategories,
  loadLatestTrending,
  loadAllTrending,
} from "../lib/mdParser";
import fs from "node:fs";
import path from "node:path";

const dashboard = parseDashboard();
const categories = loadAllCategories();
const latestTrending = loadLatestTrending();
const allTrending = loadAllTrending();

const allProjects = categories.flatMap((c) =>
  c.projects.map((p) => ({ ...p, _category: c.name }))
);

const totalRawStars = allProjects.reduce((sum, p) => sum + p.starsRaw, 0);
const fmtStars =
  totalRawStars >= 1_000_000
    ? (totalRawStars / 1_000_000).toFixed(1) + "M"
    : totalRawStars >= 1_000
      ? (totalRawStars / 1_000).toFixed(1) + "k"
      : String(totalRawStars);

// Generate sparkline data from trending files
function getStarsHistory(): number[] {
  try {
    const trendDir = path.join(process.cwd(), "Tendencias");
    const files = fs.readdirSync(trendDir)
      .filter(f => f.startsWith("Trending-") && f.endsWith(".md"))
      .sort()
      .slice(-7); // Last 7 days
    
    return files.map(file => {
      const raw = fs.readFileSync(path.join(trendDir, file), "utf-8");
      const match = raw.match(/\*\*\+([\d.kM]+) estrellas\*\* acumuladas/);
      if (!match) return 0;
      const val = match[1];
      if (val.includes("k")) return parseFloat(val) * 1000;
      if (val.includes("M")) return parseFloat(val) * 1000000;
      return parseFloat(val) || 0;
    });
  } catch {
    return [];
  }
}

const starsHistory = getStarsHistory();
---

<BaseLayout>
  <DashboardHeader
    title="Stellar Dashboard"
    subtitle="Repos curados · Categorías · Tendencias de GitHub"
    lastUpdated={dashboard.lastUpdated}
  />

  <StatsCards
    stats={[
      { value: String(dashboard.totalItems), label: "Repos curados", icon: "📦", accent: "blue", href: "#trending" },
      { value: String(dashboard.activeCategories), label: "Categorías activas", icon: "📂", accent: "green", href: "#categorias" },
      { value: String(allTrending.length), label: "Días con datos", icon: "📈", accent: "orange" },
      { 
        value: fmtStars, 
        label: "Estrellas totales", 
        icon: "⭐", 
        accent: "pink",
        sparkline: starsHistory,
        sparklineColor: "#f778ba",
      },
    ]}
  />

  {
    latestTrending && (
      <section id="trending" class="my-11 fade-in" style="animation-delay: 0.3s">
        <div class="flex items-center justify-between mb-4 pb-2.5 border-b border-surface-border">
          <h2 class="text-xl font-bold flex items-center gap-2.5">
            🔥 Trending Now <span class="text-xs font-semibold bg-stellar-accent-glow text-stellar-accent px-2.5 py-0.5 rounded-full">{latestTrending.date}</span>
          </h2>
          <a
            href={`/stellar-dashboard/tendencias/${latestTrending.slug}`}
            class="text-xs text-stellar-muted hover:text-stellar-accent transition-colors"
          >
            Ver completo →
          </a>
        </div>

        {
          latestTrending.topRepo && (
            <div class="bg-surface border border-surface-border rounded-[8px] p-3.5 mb-3.5 text-sm text-stellar-muted">
              🏆 <a href={latestTrending.topRepo.url} target="_blank" rel="noopener" class="font-semibold text-stellar-accent hover:underline">{latestTrending.topRepo.name}</a>
              lideró con <strong class="text-stellar-green">+{latestTrending.topRepo.growth.toLocaleString()}</strong> estrellas ({latestTrending.topRepo.growthPercent})
            </div>
          )
        }

        <TrendChart ranking={latestTrending.ranking} maxBars={10} height={220} />
        <div class="mt-4">
          <TrendingNowTable ranking={latestTrending.ranking} maxRows={10} />
        </div>
      </section>
    )
  }

  <section class="my-11 fade-in" style="animation-delay: 0.4s">
    <h2 class="text-xl font-bold mb-4 pb-2.5 border-b border-surface-border flex items-center gap-2.5">
      🏆 Best Quality — Mejores calificados
    </h2>
    <QualityTable projects={allProjects} maxRows={10} />
  </section>

  <section class="my-11 fade-in" style="animation-delay: 0.45s">
    <h2 class="text-xl font-bold mb-4 pb-2.5 border-b border-surface-border flex items-center gap-2.5">
      ⭐ Top Stars — Más populares
    </h2>
    <CuratedTable projects={allProjects} maxRows={10} />
  </section>

  <section id="categorias" class="my-11 fade-in" style="animation-delay: 0.5s">
    <CategoryGrid categories={categories} searchable={true} title="Categorías" />
  </section>

  {
    allTrending.length > 0 && (
      <section class="my-11 fade-in" style="animation-delay: 0.6s">
        <h2 class="text-xl font-bold mb-4 pb-2.5 border-b border-surface-border flex items-center gap-2.5">
          📈 Historial de Tendencias
          <span class="text-xs font-semibold bg-stellar-accent-glow text-stellar-accent px-2.5 py-0.5 rounded-full">{allTrending.length}</span>
        </h2>
        <div class="trend-pills">
          {allTrending.map((t) => (
            <a href={`/stellar-dashboard/tendencias/${t.slug}`} class="trend-pill">
              <span class="font-semibold">{t.date}</span>
              <span class="text-stellar-dim text-xs">{t.totalRepos} repos</span>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <Footer lastUpdated={dashboard.lastUpdated} />
</BaseLayout>

<style>
  .trend-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .trend-pill {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 8px 18px;
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: 20px;
    transition: all 0.2s;
  }
  .trend-pill:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-glow);
    transform: translateY(-1px);
  }
  .fade-in {
    animation: fadeIn 0.8s ease-out both;
  }
</style>
