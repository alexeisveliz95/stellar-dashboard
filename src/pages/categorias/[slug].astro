---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import RepoRow from "../../components/RepoRow.astro";
import { loadCategory, loadAllCategories } from "../../lib/mdParser";

export async function getStaticPaths() {
  const categories = loadAllCategories();
  return categories.map((cat) => ({
    params: { slug: cat.slug },
  }));
}

export interface Props {
  slug: string;
}

const { slug } = Astro.params;
const category = loadCategory(slug ?? "");

if (!category) {
  return Astro.redirect("/stellar-dashboard", 302);
}

const headerTitle = `📂 ${category.name} · Stellar Dashboard`;
const headerDesc = `${category.totalProjects} proyectos · Score: ${category.bestScore}`;
---

<BaseLayout title={headerTitle} description={headerDesc}>
  <Header title={category.name} subtitle={`${category.totalProjects} proyectos · ⭐ Mejor score: ${category.bestScore.toFixed(2)} · ⭐ Total: ${category.totalStars}`} />

  <section class="section fade-in">
    <div class="info-bar">
      <span>🕒 {category.lastUpdated}</span>
    </div>

    <div class="top-repos">
      {category.projects.length > 0 ? (
        category.projects.map((proj, i) => <RepoRow project={proj} rank={i + 1} showRank />)
      ) : (
        <div class="empty">No hay proyectos en esta categoría</div>
      )}
    </div>
  </section>

  <a href="/stellar-dashboard" class="back-link">← Volver al Dashboard</a>
  <Footer lastUpdated={category.lastUpdated} />
</BaseLayout>

<style>
  .section { margin-bottom: 44px; animation: fadeIn 0.8s ease-out both; }

  .info-bar {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius-sm);
    padding: 12px 20px;
    margin-bottom: 20px;
    font-size: 0.85rem;
    color: var(--text-muted);
    display: flex;
    gap: 24px;
  }

  .top-repos {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    overflow: hidden;
    backdrop-filter: blur(8px);
  }

  .empty {
    padding: 32px;
    text-align: center;
    color: var(--text-dim);
    font-size: 0.9rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 24px;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .back-link:hover { color: var(--accent); }
</style>
