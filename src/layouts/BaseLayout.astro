---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
}

const {
  title = "Stellar Dashboard — Repos curados, categorías y tendencias de GitHub",
  description = "Repos curados · Categorías · Tendencias de GitHub. Dashboard open source con los mejores repositorios de GitHub organizados por categoría y tendencias diarias.",
  image,
  type = "website",
  publishedTime,
} = Astro.props;

const siteUrl = "https://alexeisveliz95.github.io";
const base = "/stellar-dashboard";
const path = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : Astro.url.pathname + "/";
const canonical = new URL(path, siteUrl).href;
const ogImage = image
  ? image.startsWith("http")
    ? image
    : `${siteUrl}${base}${image}`
  : undefined;

const structured = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Stellar Dashboard",
  description,
  url: canonical,
};

const fontUrl =
  "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0e14" />
    <meta name="generator" content="Astro" />

    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}/favicon.svg`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={fontUrl} />
    <link rel="stylesheet" href={fontUrl} media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href={fontUrl} />
    </noscript>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Stellar Dashboard" />
    {ogImage && (
      <>
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {type === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}

    <script type="application/ld+json" set:html={JSON.stringify(structured)} />

    <style>
      :root {
        --bg: #0a0e14;
        --surface: rgba(22, 27, 34, 0.85);
        --surface-border: rgba(48, 54, 61, 0.6);
        --text: #e6edf3;
        --text-dim: #6e7681;
        --text-muted: #8b949e;
        --accent: #58a6ff;
        --accent-glow: rgba(88, 166, 255, 0.15);
        --green: #3fb950;
        --green-dim: rgba(63, 185, 80, 0.12);
        --orange: #d29922;
        --pink: #f778ba;
        --purple: #bc8cff;
        --radius: 12px;
        --radius-sm: 8px;
      }

      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        min-height: 100vh;
        background-image: radial-gradient(
            ellipse at 20% 50%,
            rgba(88, 166, 255, 0.04) 0%,
            transparent 50%
          ),
          radial-gradient(
            ellipse at 80% 20%,
            rgba(188, 140, 255, 0.04) 0%,
            transparent 50%
          ),
          radial-gradient(
            ellipse at 50% 80%,
            rgba(63, 185, 80, 0.03) 0%,
            transparent 50%
          );
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .container {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 24px;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(-10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .fade-in {
        animation: fadeIn 0.8s ease-out both;
      }

      @media (max-width: 640px) {
        .container {
          padding: 0 16px;
        }
      }

      [x-cloak] {
        display: none !important;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <slot />
    </div>

    <script>
      import Alpine from "alpinejs";

      import { repoTable } from "../lib/alpine/repoTable";
      import { categoryGrid } from "../lib/alpine/categoryGrid";
      import { trendChart } from "../lib/alpine/trendChart";

      Alpine.data("repoTable", repoTable);
      Alpine.data("categoryGrid", categoryGrid);
      Alpine.data("trendChart", trendChart);

      Alpine.start();
    </script>
  </body>
</html>
