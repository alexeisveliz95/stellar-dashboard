---
import type { CuratedWeek } from "../lib/types";

export interface Props {
  week: CuratedWeek;
}

const { week } = Astro.props;
const picks = week.picks ?? [];

function fmtStars(n: number): string {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + "M";
  if (n >= 1_000) return (n / 1_000).toFixed(1) + "k";
  return String(n);
}

function fmtGrowth(n: number): string {
  return n > 0 ? `+${n.toLocaleString("en-US")}` : n.toLocaleString("en-US");
}
---

<section class="curated-picks" data-astro-cid-curated-picks>
  <div class="meta" data-astro-cid-curated-picks>
    <span class="week-badge" data-astro-cid-curated-picks>📅 {week.week_id}</span>
    <span class="count" data-astro-cid-curated-picks>
      {picks.length} repos auto-curados · semana del {week.week_start}
    </span>
  </div>

  <div class="curated-table" data-astro-cid-curated-picks>
    {picks.map((pick, i) => (
      <div class="curated-row" data-astro-cid-curated-picks>
        <div class="rank-col" data-astro-cid-curated-picks>
          <span class="medal" data-astro-cid-curated-picks>
            {i === 0 ? "🥇" : i === 1 ? "🥈" : i === 2 ? "🥉" : `#${i + 1}`}
          </span>
        </div>
        <div class="info-col" data-astro-cid-curated-picks>
          <a href={pick.url} target="_blank" rel="noopener" data-astro-cid-curated-picks>
            {pick.name}
          </a>
          {pick.language && (
            <span class="lang" data-astro-cid-curated-picks>{pick.language}</span>
          )}
          {pick.description && (
            <div class="desc" data-astro-cid-curated-picks>{pick.description}</div>
          )}
        </div>
        <div class="stats-col" data-astro-cid-curated-picks>
          <div class="score" data-astro-cid-curated-picks title="Algorithmic score">
            {pick.score.toFixed(2)}
          </div>
          <div class="stars" data-astro-cid-curated-picks title="Stars">★ {fmtStars(pick.stars)}</div>
          <div class="growth" data-astro-cid-curated-picks title="Growth this week">
            {fmtGrowth(pick.growth)}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .curated-picks {
    display: block;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .week-badge {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    color: var(--accent);
    font-weight: 600;
    font-size: 0.78rem;
    padding: 4px 10px;
    border-radius: 999px;
    letter-spacing: 0.02em;
  }
  .count {
    color: var(--text-dim);
    font-size: 0.82rem;
  }
  .curated-table {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    overflow: hidden;
    backdrop-filter: blur(8px);
  }
  .curated-row {
    display: flex;
    align-items: center;
    padding: 10px 20px;
    border-bottom: 1px solid var(--surface-border);
    transition: background 0.15s;
    gap: 12px;
    font-size: 0.88rem;
  }
  .curated-row:last-child { border-bottom: none; }
  .curated-row:hover { background: rgba(88, 166, 255, 0.04); }
  .rank-col {
    width: 50px;
    flex-shrink: 0;
    text-align: center;
  }
  .medal {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-dim);
  }
  .info-col { flex: 1; min-width: 0; }
  .info-col a {
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .info-col a:hover { text-decoration: underline; }
  .lang {
    display: inline-block;
    margin-left: 8px;
    font-size: 0.7rem;
    color: var(--text-dim);
    background: rgba(88, 166, 255, 0.08);
    padding: 1px 7px;
    border-radius: 4px;
    vertical-align: middle;
  }
  .desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 460px;
  }
  .stats-col {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    flex-shrink: 0;
    min-width: 90px;
  }
  .score {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--accent);
  }
  .stars {
    font-size: 0.78rem;
    color: var(--text-dim);
  }
  .growth {
    font-size: 0.72rem;
    color: #58d68d;
    font-weight: 600;
  }
  @media (max-width: 640px) {
    .curated-row { padding: 10px 14px; gap: 8px; }
    .rank-col { width: 40px; }
    .desc { max-width: 220px; }
    .stats-col { min-width: 70px; }
  }
</style>
