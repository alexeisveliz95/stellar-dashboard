---
import type { TrendingRow } from "../lib/types";

export interface Props {
  ranking: TrendingRow[];
  title?: string;
  maxBars?: number;
  height?: number;
}

const { ranking, title, maxBars = 15, height = 200 } = Astro.props;

const serialized = ranking.map((row) => ({
  name: row.name,
  rank: row.rank,
  growth: row.growth,
  url: row.url,
  hot: row.hot,
}));
---

<section
  class="my-11"
  x-data="trendChart"
  x-cloak
  data-max-bars={maxBars}
>
  <script type="application/json">{JSON.stringify(serialized)}</script>

  {title && (
    <h2 class="text-xl font-bold mb-4 pb-2.5 border-b border-surface-border flex items-center gap-2.5">
      📊 {title}
    </h2>
  )}

  <div class="chart-card">
    <div class="flex items-center gap-2 text-xs text-stellar-dim mb-4">
      <span class="inline-block w-2.5 h-2.5 rounded-sm bg-stellar-green" />
      <span>Estrellas hoy</span>
      <span class="ml-auto">
        Máx: <strong class="text-stellar-text">+<span x-text="formatGrowth(maxGrowth())"></span></strong>
      </span>
    </div>

    <div
      class="chart-bars"
      style={`--chart-height: ${height}px`}
    >
      <template x-for="(row, i) in displayRows()" :key="row.name">
        <div
          class="bar-col"
          x-on:mouseenter="setHover(row)"
          x-on:mouseleave="clearHover()"
        >
          <div class="bar-value text-xs font-semibold text-stellar-dim" x-text="'+' + formatGrowth(row.growth)">
          </div>
          <div
            class="bar"
            x-bind:class="row.hot ? 'bg-gradient-to-t from-stellar-orange to-stellar-pink' : 'bg-gradient-to-t from-stellar-accent to-stellar-purple'"
            x-bind:style="'height: ' + barHeight(row.growth) + '%'"
          />
          <div class="bar-label">
            <a
              x-bind:href="row.url"
              class="text-stellar-muted hover:text-stellar-accent transition-colors"
              x-text="truncateName(row.name)"
            ></a>
          </div>
        </div>
      </template>
    </div>

    <div
      x-show="hoveredRow"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      class="mt-3 p-3 rounded-lg bg-surface border border-surface-border text-xs"
    >
      <strong x-text="hoveredRow.name"></strong> —
      <span class="text-stellar-accent" x-text="'+' + formatGrowth(hoveredRow.growth)"></span> estrellas hoy
      <span x-text="'(#' + hoveredRow.rank + ')'"></span>
    </div>

    {ranking.length > maxBars && (
      <div class="text-center mt-4">
        <button
          x-on:click="toggleShowAll()"
          class="text-xs text-stellar-accent hover:underline cursor-pointer bg-transparent border-none"
        >
          <span x-text="showAll ? `Mostrar menos (${ranking.length}) \u25B2` : `Mostrar todas (${ranking.length}) \u25BC`"></span>
        </button>
      </div>
    )}
  </div>
</section>

<style>
  .chart-card {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    padding: 20px 24px;
    backdrop-filter: blur(8px);
    position: relative;
  }

  .chart-bars {
    display: flex;
    align-items: flex-end;
    gap: 4px;
    height: var(--chart-height, 200px);
    padding-bottom: 28px;
    position: relative;
  }

  .bar-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    justify-content: flex-end;
    position: relative;
    min-width: 0;
  }

  .bar {
    width: 100%;
    max-width: 40px;
    border-radius: 4px 4px 0 0;
    transition: opacity 0.2s;
    min-height: 2px;
  }

  .bar-col:hover .bar { opacity: 0.8; }

  .bar-value {
    margin-bottom: 3px;
    white-space: nowrap;
  }

  .bar-label {
    position: absolute;
    bottom: -24px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.65rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 60px;
    text-align: center;
  }

  .bar-label a {
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .chart-card { padding: 16px; }
    .bar { max-width: 24px; }
    .bar-value { font-size: 0.6rem; }
    .bar-label { max-width: 40px; font-size: 0.55rem; }
  }
</style>
