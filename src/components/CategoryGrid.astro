---
import type { CategorySummary, CategoryDetail } from "../lib/types";

export interface Props {
  categories: CategorySummary[] | CategoryDetail[];
  searchable?: boolean;
  columns?: number;
  title?: string;
}

const { categories, searchable = false, columns = 3, title } = Astro.props;

const emojiMap: Record<string, string> = {
  "AI & Data Science": "🤖",
  "Cybersecurity & Hacking": "🛡️",
  "Web3 & Blockchain": "🔗",
  "Mobile Development": "📱",
  "PlayStation Homebrew & Linux": "🎮",
  "Python & Backend": "🐍",
  "Web Development": "🌐",
  "Automation & DevOps": "⚡",
  "Otros": "📦",
};

const serialized = categories.map((cat) => ({
  title: "name" in cat ? cat.name : "",
  slug: "slug" in cat ? cat.slug : "",
  count: "projects" in cat ? cat.projects.length : ("totalProjects" in cat ? cat.totalProjects : 0),
  description: "description" in cat ? (cat.description || "") : "",
  emoji: emojiMap[("name" in cat ? cat.name : "")] || "📁",
}));
---

    <section id="categorias" class="my-11" x-data="categoryGrid" x-cloak>
  <div hidden>{JSON.stringify(serialized)}</div>

  {title && (
    <h2 class="text-xl font-bold mb-4 pb-2.5 border-b border-surface-border flex items-center gap-2.5">
      📂 {title}
      <span class="text-xs font-semibold bg-stellar-accent-glow text-stellar-accent px-2.5 py-0.5 rounded-full">
        <span x-text="filtered.length"></span>/<span x-text="all.length"></span>
      </span>
    </h2>
  )}

  {searchable && (
    <input
      type="text"
      x-model="search"
      @input.debounce="apply"
      placeholder="Buscar categoría..."
      class="w-full mb-4 px-4 py-2.5 rounded-lg bg-surface border border-surface-border text-stellar-text placeholder-stellar-dim text-sm outline-none focus:border-stellar-accent focus:ring-1 focus:ring-stellar-accent/30 transition-all"
    />
  )}

  <div class="cat-grid" style={`--cols: ${columns}`}>
    <template x-for="cat in filtered" :key="cat.slug">
      <a
        x-bind:href="`/stellar-dashboard/categorias/${cat.slug}`"
        class="cat-card group"
      >
        <span class="font-semibold flex items-center gap-2">
          <span class="text-lg" x-text="cat.emoji"></span>
          <span x-text="cat.title"></span>
        </span>
        <span class="cat-count" x-text="cat.count + (cat.count === 1 ? ' repo' : ' repos')"></span>
      </a>
    </template>
  </div>

  <div x-show="filtered.length === 0" class="py-8 text-center text-stellar-dim text-sm">
    No se encontraron categorías con ese filtro.
  </div>
</section>

<style>
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), 1fr);
    gap: 12px;
  }

  .cat-card {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius-sm);
    padding: 16px 20px;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    backdrop-filter: blur(8px);
    color: var(--text);
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .cat-card:hover {
    transform: translateY(-2px);
    border-color: rgba(88, 166, 255, 0.3);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.25);
  }

  .cat-count {
    color: var(--text-muted);
    font-size: 0.82rem;
    font-weight: 500;
    background: rgba(139, 148, 158, 0.1);
    padding: 2px 10px;
    border-radius: 20px;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .cat-grid { grid-template-columns: 1fr; }
  }
</style>
