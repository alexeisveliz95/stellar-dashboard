---
import type { TrendingRow } from "../lib/types";

export interface Props {
  ranking: TrendingRow[];
  maxRows?: number;
}

const { ranking, maxRows = 10 } = Astro.props;
const top = ranking.slice(0, maxRows);
---

<div class="trend-now-table">
  {top.map((row) => (
    <div class="trend-now-row">
      <div class="rank-col">
        <span class="rank-icon">{row.hot ? "🔥" : "📈"}</span>
        <span class="rank-num">#{row.rank}</span>
      </div>
      <div class="info-col">
        <a href={row.url} target="_blank" rel="noopener">{row.name}</a>
        <span class="owner">`{row.owner}`</span>
      </div>
      <div class="stars-col">★ {row.stars}</div>
      <div class="growth-col">+{row.growth.toLocaleString()}</div>
    </div>
  ))}
</div>

<style>
  .trend-now-table {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    overflow: hidden;
    backdrop-filter: blur(8px);
  }
  .trend-now-row {
    display: flex;
    align-items: center;
    padding: 10px 20px;
    border-bottom: 1px solid var(--surface-border);
    transition: background 0.15s;
    gap: 12px;
    font-size: 0.88rem;
  }
  .trend-now-row:last-child { border-bottom: none; }
  .trend-now-row:hover { background: rgba(88, 166, 255, 0.04); }
  .rank-col {
    width: 70px;
    flex-shrink: 0;
    font-weight: 600;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .rank-icon { font-size: 0.9rem; }
  .rank-num { font-size: 0.8rem; }
  .info-col { flex: 1; min-width: 0; }
  .info-col a { font-weight: 600; color: var(--accent); text-decoration: none; }
  .info-col a:hover { text-decoration: underline; }
  .info-col .owner {
    font-size: 0.78rem;
    color: var(--text-dim);
    margin-left: 6px;
    font-family: monospace;
  }
  .stars-col {
    width: 80px;
    text-align: right;
    color: var(--text-dim);
    font-weight: 600;
    flex-shrink: 0;
  }
  .growth-col {
    width: 80px;
    text-align: right;
    color: #22d3ee;
    font-weight: 700;
    flex-shrink: 0;
  }
  @media (max-width: 640px) {
    .trend-now-row { padding: 10px 14px; gap: 8px; }
    .rank-col { width: 50px; }
    .stars-col, .growth-col { width: auto; }
  }
</style>
