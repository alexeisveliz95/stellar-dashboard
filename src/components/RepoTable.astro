---
import type { ProjectRow } from "../lib/types";

export interface Props {
  projects: ProjectRow[];
  title?: string;
  searchable?: boolean;
  sortable?: boolean;
  maxHeight?: string;
}

const { projects, title, searchable = true, sortable = true, maxHeight } = Astro.props;

const serialized = projects.map((p, i) => ({
  name: p.name,
  description: p.description || "",
  score: p.score,
  stars: p.starsRaw,
  url: p.url,
  momentumBar: p.momentumBar,
  rank: i + 1,
}));
---

    <section class="my-11" x-data="repoTable" x-cloak>
  <div hidden>{JSON.stringify(serialized)}</div>

  {title && (
    <h2 class="text-xl font-bold mb-4 pb-2.5 border-b border-surface-border flex items-center gap-2.5">
      📋 {title}
      <span class="text-xs font-semibold bg-stellar-accent-glow text-stellar-accent px-2.5 py-0.5 rounded-full">
        <span x-text="filtered.length"></span>/<span x-text="all.length"></span>
      </span>
    </h2>
  )}

  <div class="flex flex-wrap gap-3 mb-4 items-center">
    {searchable && (
      <input
        type="text"
        x-model="search"
        @input.debounce="apply"
        placeholder="Buscar por nombre o descripción..."
        class="flex-1 min-w-[200px] px-4 py-2.5 rounded-lg bg-surface border border-surface-border text-stellar-text placeholder-stellar-dim text-sm outline-none focus:border-stellar-accent focus:ring-1 focus:ring-stellar-accent/30 transition-all"
      />
    )}

    {sortable && (
      <>
        <select
          x-model="sortKey"
          @change="apply"
          class="px-3 py-2.5 rounded-lg bg-surface border border-surface-border text-stellar-text text-sm outline-none focus:border-stellar-accent focus:ring-1 focus:ring-stellar-accent/30 transition-all"
        >
          <option value="score">Score ↓</option>
          <option value="stars">Stars ↓</option>
          <option value="name">A → Z</option>
        </select>

        <select
          x-model="filterKey"
          @change="apply"
          class="px-3 py-2.5 rounded-lg bg-surface border border-surface-border text-stellar-text text-sm outline-none focus:border-stellar-accent focus:ring-1 focus:ring-stellar-accent/30 transition-all"
        >
          <option value="all">Score: todos</option>
          <option value="high">≥ 0.80</option>
          <option value="medium">0.50 – 0.79</option>
          <option value="low">&lt; 0.50</option>
        </select>
      </>
    )}

    <span class="text-xs text-stellar-dim ml-auto" x-text="`${filtered.length} de ${all.length} repos`"></span>
  </div>

  <div
    class="repo-container"
    style={maxHeight ? { maxHeight, overflowY: "auto" } : undefined}
  >
    <div class="repo-header">
      <div class="w-9 flex-shrink-0" />
      <div class="flex-1 text-xs uppercase tracking-wider text-stellar-dim font-semibold">Repositorio</div>
      <div class="w-[70px] text-right text-xs uppercase tracking-wider text-stellar-dim font-semibold">Stars</div>
      <div class="w-[60px] text-right text-xs uppercase tracking-wider text-stellar-dim font-semibold">Score</div>
      <div class="w-[90px] text-center text-xs uppercase tracking-wider text-stellar-dim font-semibold">Momentum</div>
    </div>

    <template x-for="(repo, index) in filtered" :key="repo.name">
      <div class="repo-row">
        <div class="rank-badge" x-bind:class="rankClass(index)">
          <span x-text="rankLabel(index)"></span>
        </div>
        <div class="flex-1 min-w-0">
          <a
            x-bind:href="repo.url"
            target="_blank"
            rel="noopener"
            class="font-semibold text-sm text-stellar-accent hover:underline"
            x-text="repo.name"
          ></a>
          <div
            x-show="repo.description"
            class="text-xs text-stellar-muted mt-0.5 truncate max-w-[420px]"
            x-text="repo.description"
          />
        </div>
        <div class="w-[70px] text-right text-sm font-semibold text-stellar-dim flex-shrink-0">
          ★ <span x-text="repo.stars"></span>
        </div>
        <div class="w-[60px] text-right text-sm font-semibold text-stellar-purple flex-shrink-0" x-text="repo.score.toFixed(2)">
        </div>
        <div class="w-[90px] text-center text-xs tracking-wider text-stellar-dim font-mono flex-shrink-0" x-text="repo.momentumBar">
        </div>
      </div>
    </template>

    <div x-show="filtered.length === 0" class="py-8 text-center text-stellar-dim text-sm">
      No se encontraron repositorios con ese filtro.
    </div>
  </div>
</section>

<style>
  .repo-container {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    overflow: hidden;
    backdrop-filter: blur(8px);
  }

  .repo-header, .repo-row {
    display: flex;
    align-items: center;
    padding: 10px 20px;
    gap: 12px;
  }

  .repo-header {
    border-bottom: 1px solid var(--surface-border);
    background: rgba(139, 148, 158, 0.04);
  }

  .repo-row {
    border-bottom: 1px solid var(--surface-border);
    transition: background 0.15s;
  }

  .repo-row:last-child { border-bottom: none; }
  .repo-row:hover { background: rgba(88, 166, 255, 0.04); }

  .rank-badge {
    width: 36px;
    font-weight: 700;
    color: var(--text-dim);
    font-size: 0.85rem;
    text-align: center;
    flex-shrink: 0;
  }
  .rank-badge.gold { color: #ffd700; font-size: 1.1rem; }
  .rank-badge.silver { color: #c0c0c0; }
  .rank-badge.bronze { color: #cd7f32; }

  @media (max-width: 640px) {
    .repo-header, .repo-row { padding: 10px 14px; gap: 8px; flex-wrap: wrap; }
    .rank-badge { width: 28px; }
  }
</style>
