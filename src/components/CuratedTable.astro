---
import type { ProjectRow } from "../lib/types";

export interface Props {
  projects: ProjectRow[];
  maxRows?: number;
}

const { projects, maxRows = 10 } = Astro.props;
const sorted = [...projects].sort((a, b) => b.starsRaw - a.starsRaw).slice(0, maxRows);
---

<div class="curated-table">
  {sorted.map((proj, i) => (
    <div class="curated-row">
      <div class="rank-col">#{i + 1}</div>
      <div class="info-col">
        <a href={proj.url} target="_blank" rel="noopener">{proj.name}</a>
        <div class="desc">{proj.description}</div>
      </div>
      <div class="stars-col">★ {proj.stars}</div>
    </div>
  ))}
</div>

<style>
  .curated-table {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    overflow: hidden;
    backdrop-filter: blur(8px);
  }
  .curated-row {
    display: flex;
    align-items: center;
    padding: 10px 20px;
    border-bottom: 1px solid var(--surface-border);
    transition: background 0.15s;
    gap: 12px;
    font-size: 0.88rem;
  }
  .curated-row:last-child { border-bottom: none; }
  .curated-row:hover { background: rgba(88, 166, 255, 0.04); }
  .rank-col {
    width: 50px;
    flex-shrink: 0;
    font-weight: 600;
    color: var(--text-dim);
    font-size: 0.8rem;
  }
  .info-col { flex: 1; min-width: 0; }
  .info-col a { font-weight: 600; color: var(--accent); text-decoration: none; }
  .info-col a:hover { text-decoration: underline; }
  .desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 400px;
  }
  .stars-col {
    width: 80px;
    text-align: right;
    color: var(--text-dim);
    font-weight: 600;
    flex-shrink: 0;
  }
  @media (max-width: 640px) {
    .curated-row { padding: 10px 14px; gap: 8px; }
    .rank-col { width: 40px; }
    .desc { max-width: 200px; }
    .stars-col { width: auto; }
  }
</style>
