---
import type { TopFiveDetail } from "../lib/types";

export interface Props {
  items: TopFiveDetail[];
}

const { items } = Astro.props;
const medalEmojis: Record<number, string> = { 1: "🥇", 2: "🥈", 3: "🥉", 4: "4️⃣", 5: "5️⃣" };
---

<div class="top-five">
  {items.map((item) => (
    <div class="detail-card">
      <div class="detail-header">
        <span class="medal">{medalEmojis[item.rank] || `#${item.rank}`}</span>
        <a href={item.url} target="_blank" rel="noopener">{item.name}</a>
      </div>

      <blockquote>{item.description}</blockquote>

      <div class="metrics">
        <div class="metric">
          <span class="metric-label">⭐ Stars</span>
          <span class="metric-value">{item.stars}</span>
          <span class="metric-sub">{item.tierIcon} {item.threshold}</span>
        </div>
        <div class="metric">
          <span class="metric-label">🚀 Growth</span>
          <span class="metric-value green">+{item.growth.toLocaleString()}</span>
        </div>
        <div class="metric">
          <span class="metric-label">📊 Momentum</span>
          <span class="metric-value mono">{item.momentumBar}</span>
        </div>
        <div class="metric">
          <span class="metric-label">🏷️ Score</span>
          <span class="metric-value">{item.score.toFixed(1)}</span>
        </div>
      </div>
    </div>
  ))}
</div>

<style>
  .top-five { display: flex; flex-direction: column; gap: 16px; }

  .detail-card {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    padding: 20px 24px;
    backdrop-filter: blur(8px);
    transition: border-color 0.2s;
  }

  .detail-card:hover { border-color: rgba(88, 166, 255, 0.3); }

  .detail-header { margin-bottom: 10px; }
  .detail-header .medal { font-size: 1.3rem; margin-right: 8px; }
  .detail-header a { font-size: 1.05rem; font-weight: 700; }

  blockquote {
    color: var(--text-muted);
    font-size: 0.88rem;
    border-left: 3px solid var(--surface-border);
    padding-left: 16px;
    margin-bottom: 16px;
    font-style: italic;
  }

  .metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .metric-label {
    font-size: 0.75rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .metric-value {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .metric-value.green { color: var(--green); }
  .metric-value.mono { letter-spacing: 1px; font-size: 0.85rem; }

  .metric-sub {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .metrics { grid-template-columns: repeat(2, 1fr); }
    .detail-card { padding: 16px; }
  }
</style>
