---
import type { TrendingRow } from "../lib/types";

export interface Props {
  ranking: TrendingRow[];
}

const { ranking } = Astro.props;
---

<div class="trend-table">
  {ranking.map((row) => (
    <div class="trend-row">
      <div class="rank-col">{row.hot ? "🔥" : "📈"} <span class="rank-num">#{row.rank}</span></div>
      <div class="info-col">
        <a href={row.url} target="_blank" rel="noopener">{row.name}</a>
        <span class="owner">`{row.owner}`</span>
      </div>
      <div class="stars-col">★ {row.stars}</div>
      <div class="growth-col">+{row.growth.toLocaleString()}</div>
      <div class="mom-col">{row.momentumBar}</div>
    </div>
  ))}
</div>

<style>
  .trend-table {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    overflow: hidden;
    backdrop-filter: blur(8px);
  }

  .trend-row {
    display: flex;
    align-items: center;
    padding: 10px 20px;
    border-bottom: 1px solid var(--surface-border);
    transition: background 0.15s;
    gap: 12px;
    font-size: 0.88rem;
  }

  .trend-row:last-child { border-bottom: none; }
  .trend-row:hover { background: rgba(88, 166, 255, 0.04); }

  .rank-col {
    width: 70px;
    flex-shrink: 0;
    font-weight: 600;
    color: var(--text-dim);
  }

  .rank-num { font-size: 0.8rem; margin-left: 4px; }

  .info-col { flex: 1; min-width: 0; }
  .info-col a { font-weight: 600; }
  .info-col .owner {
    font-size: 0.78rem;
    color: var(--text-dim);
    margin-left: 6px;
    font-family: monospace;
  }

  .stars-col { width: 80px; text-align: right; color: var(--text-dim); font-weight: 600; flex-shrink: 0; }
  .growth-col { width: 80px; text-align: right; color: var(--green); font-weight: 700; flex-shrink: 0; }
  .mom-col { width: 80px; text-align: center; letter-spacing: 1px; font-size: 0.75rem; color: var(--text-dim); flex-shrink: 0; }

  @media (max-width: 640px) {
    .trend-row { flex-wrap: wrap; padding: 10px 14px; }
    .mom-col { display: none; }
    .stars-col, .growth-col { width: auto; }
  }
</style>
