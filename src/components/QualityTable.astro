---
import type { ProjectRow } from "../lib/types";

export interface Props {
  projects: ProjectRow[];
  maxRows?: number;
}

const { projects, maxRows = 10 } = Astro.props;
const sorted = [...projects].sort((a, b) => b.score - a.score).slice(0, maxRows);

function scorePill(score: number): string {
  if (score >= 0.8) return "score-high";
  if (score >= 0.5) return "score-medium";
  return "score-low";
}
---

<div class="quality-table">
  {sorted.map((proj, i) => (
    <div class="quality-row">
      <div class="rank-col">#{i + 1}</div>
      <div class="info-col">
        <a href={proj.url} target="_blank" rel="noopener">{proj.name}</a>
      </div>
      <div class="score-col">
        <span class={`score-pill ${scorePill(proj.score)}`}>{proj.score.toFixed(2)}</span>
      </div>
      <div class="stars-col">★ {proj.stars}</div>
    </div>
  ))}
</div>

<style>
  .quality-table {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    overflow: hidden;
    backdrop-filter: blur(8px);
  }
  .quality-row {
    display: flex;
    align-items: center;
    padding: 10px 20px;
    border-bottom: 1px solid var(--surface-border);
    transition: background 0.15s;
    gap: 12px;
    font-size: 0.88rem;
  }
  .quality-row:last-child { border-bottom: none; }
  .quality-row:hover { background: rgba(88, 166, 255, 0.04); }
  .rank-col {
    width: 50px;
    flex-shrink: 0;
    font-weight: 600;
    color: var(--text-dim);
    font-size: 0.8rem;
  }
  .info-col { flex: 1; min-width: 0; }
  .info-col a { font-weight: 600; color: var(--accent); text-decoration: none; }
  .info-col a:hover { text-decoration: underline; }
  .score-col { width: 70px; text-align: center; flex-shrink: 0; }
  .score-pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 0.78rem;
    font-weight: 600;
  }
  .score-high { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
  .score-medium { background: rgba(234, 179, 8, 0.15); color: #eab308; }
  .score-low { background: rgba(156, 163, 175, 0.15); color: #9ca3af; }
  .stars-col {
    width: 80px;
    text-align: right;
    color: var(--text-dim);
    font-weight: 600;
    flex-shrink: 0;
  }
  @media (max-width: 640px) {
    .quality-row { padding: 10px 14px; gap: 8px; }
    .rank-col { width: 40px; }
    .stars-col { width: auto; }
  }
</style>
