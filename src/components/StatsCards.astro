---
import MiniSparkline from "./MiniSparkline.astro";

export interface StatItem {
  value: string;
  label: string;
  icon?: string;
  accent: "blue" | "green" | "orange" | "pink";
  href?: string;
  sparkline?: number[];
  sparklineColor?: string;
}

export interface Props {
  stats: StatItem[];
  columns?: number;
}

const { stats, columns = 4 } = Astro.props;

const accentMap: Record<string, { bar: string; text: string }> = {
  blue:   { bar: "from-stellar-accent to-stellar-purple", text: "text-stellar-accent" },
  green:  { bar: "from-stellar-green to-stellar-accent",  text: "text-stellar-green" },
  orange: { bar: "from-stellar-orange to-stellar-pink",   text: "text-stellar-orange" },
  pink:   { bar: "from-stellar-pink to-stellar-purple",   text: "text-stellar-pink" },
};
---

<div
  class="stats-grid"
  style={`--cols: ${columns}`}
>
  {stats.map((s) => {
    const a = accentMap[s.accent] || accentMap.blue;
    const content = (
      <div class="stat-card group">
        <div class={`bar ${a.bar}`} />
        <div class="stat-content">
          {s.icon && <div class="stat-icon">{s.icon}</div>}
          <div class={`stat-value ${a.text}`}>{s.value}</div>
          <div class="stat-label">{s.label}</div>
          {s.sparkline && s.sparkline.length > 1 && (
            <div class="stat-sparkline">
              <MiniSparkline
                data={s.sparkline}
                color={s.sparklineColor || "#58a6ff"}
                width={80}
                height={20}
              />
            </div>
          )}
        </div>
      </div>
    );
    return s.href ? <a href={s.href}>{content}</a> : content;
  })}
</div>

<style>
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 4), 1fr);
    gap: 16px;
    margin: 32px 0 44px;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius);
    backdrop-filter: blur(8px);
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    cursor: default;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .stat-card:hover {
    transform: translateY(-3px);
    border-color: rgba(88, 166, 255, 0.3);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .stat-content {
    text-align: center;
    padding: 24px 16px;
    width: 100%;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .stat-icon {
    font-size: 1.75rem;
    margin-bottom: 8px;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .stat-label {
    color: var(--text-dim);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 6px;
    font-weight: 500;
  }

  .stat-sparkline {
    margin-top: 12px;
    display: flex;
    justify-content: center;
  }

  .bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .stat-card:hover .bar { opacity: 1; }

  @media (max-width: 640px) {
    .stats-grid { 
      grid-template-columns: repeat(2, 1fr); 
      gap: 10px; 
    }
    .stat-content {
      padding: 16px 12px;
    }
    .stat-icon {
      font-size: 1.5rem;
      margin-bottom: 6px;
    }
    .stat-value {
      font-size: 1.5rem;
    }
    .stat-label {
      font-size: 0.65rem;
    }
    .stat-sparkline {
      margin-top: 8px;
    }
  }
</style>
